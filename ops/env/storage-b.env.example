# Copy to /etc/rust-victoria-trace/storage-b.env on the second storage host.
VT_ROLE=storage
VT_BIND_ADDR=0.0.0.0:13011
VT_STORAGE_MODE=disk
VT_STORAGE_PATH=/data/rust-victoria-trace/storage-b
VT_TRACE_INGEST_PROFILE=throughput
VT_STORAGE_SYNC_POLICY=none
VT_STORAGE_TARGET_SEGMENT_SIZE_BYTES=268435456
VT_STORAGE_TRACE_SEAL_WORKER_COUNT=4
VT_STORAGE_RETENTION_HOURS=24
# 只在明确接受 active head crash-loss 时关闭；默认建议保留 WAL。
# VT_STORAGE_TRACE_WAL_ENABLED=false
VT_INTERNAL_BEARER_TOKEN=change-me-internal
