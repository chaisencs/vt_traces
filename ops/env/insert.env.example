# Copy to /etc/rust-victoria-trace/insert.env on the insert host.
VT_ROLE=insert
VT_BIND_ADDR=0.0.0.0:13001
VT_CLUSTER_STORAGE_NODES=http://storage-a:13011,http://storage-b:13011
VT_CLUSTER_REPLICATION_FACTOR=2
VT_CLUSTER_WRITE_QUORUM=2
VT_INTERNAL_BEARER_TOKEN=change-me-internal
VT_API_BEARER_TOKEN=change-me-public
