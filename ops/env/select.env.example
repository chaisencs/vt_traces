# Copy to /etc/rust-victoria-trace/select.env on the select host.
VT_ROLE=select
VT_BIND_ADDR=0.0.0.0:13002
VT_CLUSTER_STORAGE_NODES=http://storage-a:13011,http://storage-b:13011
VT_CLUSTER_CONTROL_NODES=http://select-a:13002
VT_CLUSTER_REPLICATION_FACTOR=2
VT_CLUSTER_WRITE_QUORUM=2
VT_CLUSTER_READ_QUORUM=1
VT_INTERNAL_BEARER_TOKEN=change-me-internal
VT_API_BEARER_TOKEN=change-me-public
VT_ADMIN_BEARER_TOKEN=change-me-admin
# Optional:
# VT_CLUSTER_STORAGE_TOPOLOGY=http://storage-a:13011=az-a,http://storage-b:13011=az-b
# VT_CLUSTER_STORAGE_WEIGHTS=http://storage-a:13011=100,http://storage-b:13011=100
