# Copy to /etc/rust-victoria-trace/storage-a.env on the first storage host.
VT_ROLE=storage
VT_BIND_ADDR=0.0.0.0:13011
VT_STORAGE_MODE=disk
VT_STORAGE_PATH=/data/rust-victoria-trace/storage-a
VT_TRACE_INGEST_PROFILE=throughput
VT_STORAGE_SYNC_POLICY=none
VT_STORAGE_TARGET_SEGMENT_SIZE_BYTES=67108864
VT_STORAGE_TRACE_SEAL_WORKER_COUNT=4
VT_INTERNAL_BEARER_TOKEN=change-me-internal
